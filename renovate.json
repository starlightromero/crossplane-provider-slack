{
  "extends": [
    "config:best-practices",
    ":semanticCommits"
  ],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Group all GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "automerge": false
    },
    {
      "description": "Group all Go module patch updates",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["patch"],
      "groupName": "go-patch-updates",
      "automerge": true
    },
    {
      "description": "Group Crossplane and Upjet updates",
      "matchManagers": ["gomod"],
      "matchPackagePrefixes": [
        "github.com/crossplane/",
        "github.com/crossplane-contrib/"
      ],
      "groupName": "crossplane-ecosystem"
    },
    {
      "description": "Group Kubernetes client updates",
      "matchManagers": ["gomod"],
      "matchPackagePrefixes": [
        "k8s.io/",
        "sigs.k8s.io/"
      ],
      "groupName": "kubernetes-deps"
    },
    {
      "description": "Automerge Dockerfile base image patch updates",
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["patch"],
      "automerge": true
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  }
}
